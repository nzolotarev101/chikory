{
  "name": "@chikory/sdk",
  "version": "0.0.1",
  "description": "Vendor-neutral SDK for long-running software agents with durable execution and Agent-as-a-Judge",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "agents",
    "orchestration",
    "durable-execution",
    "agent-judge"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@temporalio/activity": "^1.13.0",
    "@temporalio/client": "^1.13.0",
    "@temporalio/worker": "^1.13.0",
    "@temporalio/workflow": "^1.13.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  }
}
