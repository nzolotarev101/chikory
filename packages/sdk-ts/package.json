  "keywords": ["llm", "agents", "orchestration", "durable-execution", "agent-judge"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "dependencies": {}
