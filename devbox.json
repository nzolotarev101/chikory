{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": [
    "nodejs@22",
    "pnpm@latest",
    "python@3.11",
    "uv@latest",
    "ruff@latest",
    "temporal-cli@latest"
  ],
  "shell": {
    "init_hook": [],
    "scripts": {
      // Canonical task entry points — all humans, agents, and CI use these.
      "bootstrap": "pnpm install && uv --directory packages/sdk-py sync",
      "build": "pnpm -r build",
      "temporal-dev": "temporal server start-dev",
      "lint": "pnpm -r lint && ruff check packages/sdk-py && ruff format --check packages/sdk-py",
      "typecheck": "pnpm -r typecheck && (cd packages/sdk-py && uv run pyright)",
      "test": "pnpm -r test && (cd packages/sdk-py && uv run pytest)",
      "smoke": "bash scripts/smoke.sh",
      "dogfood": "bash scripts/dogfood.sh",
      "harvest": "bash scripts/harvest.sh"
    }
  }
}