{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": [
    "nodejs@22",
    "pnpm@latest",
    "python@3.11",
    "uv@latest",
    "ruff@latest",
    "temporal-cli@latest"
  ],
  "env": {
    "NODE_OPTIONS": "--disable-warning=ExperimentalWarning"
  },
  "shell": {
    "init_hook": [],
    "scripts": {
      // Canonical task entry points — all humans, agents, and CI use these.
      "bootstrap": "pnpm install && uv --directory packages/sdk-py sync",
      "build": "pnpm -r build",
      "temporal-dev": "temporal server start-dev",
      "lint": "pnpm -r lint && ruff check packages/sdk-py && ruff format --check packages/sdk-py",
      "typecheck": "pnpm -r typecheck && (cd packages/sdk-py && uv run pyright)",
      "test": "pnpm -r test && (cd packages/sdk-py && uv run pytest) && bash scripts/test-harvest-chain.sh",
      "smoke": "bash scripts/smoke.sh",
      "run-dogfood": "bash scripts/dogfood.sh --run",
      "chain-dogfood": "bash scripts/dogfood.sh --chain",
      "dogfood-verify": "bash scripts/dogfood-verify.sh",
      "dogfood-progression": "bash scripts/dogfood-progression.sh",
      "bench": "bash scripts/bench.sh",
      "judge-proxy": "node scripts/cli-judge-proxy.mjs 8787 agy",
      "harvest": "bash scripts/harvest.sh \"\" main",
      "harvest-audit": "bash scripts/harvest-audit.sh"
    }
  }
}
